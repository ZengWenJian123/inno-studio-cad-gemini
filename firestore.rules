rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny ALL
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incomingData() {
      return request.resource.data;
    }

    function isValidProject(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100
          && data.userId == request.auth.uid
          && data.messages is list
          && data.lastUpdated is number;
    }

    match /projects/{projectId} {
      allow get: if isOwner(resource.data.userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() 
                    && isValidId(projectId)
                    && isValidProject(incomingData())
                    && incomingData().userId == request.auth.uid;
                    
      allow update: if isOwner(resource.data.userId)
                    && isValidProject(incomingData())
                    && incomingData().userId == resource.data.userId
                    && (
                      // Only allow updating name, messages, lastUpdated, thumbnail
                      incomingData().diff(resource.data).affectedKeys().hasOnly(['name', 'messages', 'lastUpdated', 'thumbnail'])
                    );
                    
      allow delete: if isOwner(resource.data.userId);
    }

    match /templates/{templateId} {
      allow read: if resource.data.isPublic == true || isOwner(resource.data.userId);
      allow create: if isSignedIn() && incomingData().userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.userId);
    }
  }
}
